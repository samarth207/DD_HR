{
  "name": "hr-portal-server",
  "version": "1.0.0",
  "description": "HR Portal Backend Server with MongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:email": "node scripts/test-email.js",
    "test:e2e": "jest --runInBand --config jest.e2e.config.js",
    "test:automation": "npm run test:e2e",
    "test:e2e:report": "cross-env PERSIST_TEST_REPORTS=true jest --runInBand --config jest.e2e.config.js",
    "test:case:new": "node scripts/generate-test-case.js"
  },
  "keywords": [
    "hr",
    "mongodb",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongodb": "^7.2.0",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^10.3.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4"
  }
}
